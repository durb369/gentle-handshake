<!--
  ANDROID MANIFEST PERMISSIONS REFERENCE
  ======================================
  After running `npx cap add android`, add these permissions to:
  android/app/src/main/AndroidManifest.xml (inside the <manifest> tag, before <application>)
-->

<!-- Camera access for spirit scanning -->
<uses-permission android:name="android.permission.CAMERA" />
<uses-feature android:name="android.hardware.camera" android:required="false" />
<uses-feature android:name="android.hardware.camera.front" android:required="false" />

<!-- Storage for saving scans and sketches -->
<uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
<uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="29" />
<uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

<!-- Internet for AI analysis -->
<uses-permission android:name="android.permission.INTERNET" />
<uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

<!--
  NOTE: @capacitor/camera and @capacitor/filesystem plugins auto-register
  most of these permissions. This file serves as a reference to verify
  they're present after running `npx cap sync android`.
-->
